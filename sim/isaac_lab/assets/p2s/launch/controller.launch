<launch>

<rosparam file="$(find BAMBULAB_P2S_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="BAMBULAB_P2S" args="Z-axis_position_controller Y-axis_position_controller X-axis_position_controller Revolute 8_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/BAMBULAB_P2S/joint_states"/>
</node>

</launch>